{
  "version": "1.2",
  "_description": "中等配置: FFN 40% + attn proj 10% + heads 30%, 预期参数缩减 ~25%, AMOTA 下降 2-4%",

  "locked": {
    "importance_criterion": "taylor",
    "pruning_granularity": "local",
    "iterative_steps": 5,
    "round_to": 8
  },

  "encoder": {
    "ffn_mid_ratio": 0.6,
    "attn_proj_ratio": 0.1,
    "head_pruning_ratio": 0.0
  },
  "decoder": {
    "ffn_mid_ratio": 0.6,
    "attn_proj_ratio": 0.1,
    "head_pruning_ratio": 0.0,
    "num_layers": 6
  },
  "heads": {
    "head_mid_ratio": 0.7
  },

  "finetune": {
    "epochs": 10
  },
  "constraints": {
    "skip_layers": ["sampling_offsets", "attention_weights"],
    "min_channels": 64,
    "channel_alignment": 8
  }
}
