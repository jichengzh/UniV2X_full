{
  "version": "1.2",
  "_description": "P1 + seg_head mask_MLP 30%: FFN 30% 扩展到 seg_head.stuff/things_mask_head 的 MLP",
  "_note": "相比 p1_ffn_30pct.json, 新增 10 个 mask_head MLP 剪枝 (5.26M->3.68M)",
  "locked": {
    "importance_criterion": "l1_norm",
    "pruning_granularity": "local",
    "iterative_steps": 5,
    "round_to": 8
  },
  "encoder": { "ffn_mid_ratio": 0.7, "attn_proj_ratio": 0.0, "head_pruning_ratio": 0.0 },
  "decoder": { "ffn_mid_ratio": 0.7, "attn_proj_ratio": 0.0, "head_pruning_ratio": 0.0, "num_layers": 6 },
  "heads": { "head_mid_ratio": 1.0 },
  "finetune": { "epochs": 0 },
  "constraints": {
    "skip_layers": ["sampling_offsets", "attention_weights"],
    "min_channels": 64,
    "channel_alignment": 8
  }
}
